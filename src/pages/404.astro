---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found - Nick Woods">
  <div class="cs-content">
    <div style="text-align: center; padding: 120px 20px;">
      <h1 style="font-size: 72px; margin-bottom: 24px;">404</h1>
      <h2 style="margin-bottom: 40px;">Page Not Found</h2>
      <p style="margin-bottom: 40px; max-width: 500px; margin-left: auto; margin-right: auto;">
        The page you're looking for doesn't exist. It might have been moved, deleted, or the URL might be incorrect.
      </p>
      <a href="/" style="display: inline-block; padding: 12px 24px; background-color: var(--accent-primary); color: var(--bg-primary); border-radius: 8px; text-decoration: none; border: none;">
        Go Home
      </a>
    </div>
  </div>
</Base>