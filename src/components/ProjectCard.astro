---
export interface Props {
  title: string;
  credits?: string;
  image: string;
  contentfulId: string;
}

const { title, credits, image, contentfulId } = Astro.props;
---

<div class="Cards">
  <a href={`/case-studies/${contentfulId}`} class="CardLink">
    <div class="CardStyle" style={`background-image: url(${image})`}>
      <div class="TitleGroup">
        <h3 class="Title">{title}</h3>
        {credits && <p class="Credits">{credits}</p>}
      </div>
    </div>
  </a>
</div>

<style>
  .Cards {
    border: none;
    border-radius: 16px;
    overflow: hidden;
  }

  .CardStyle {
    background-size: cover;
    width: 100%;
    height: 390px;
    position: relative;
    overflow: hidden;
    border-radius: 16px;
  }

  .TitleGroup {
    height: 310px;
    opacity: 0;
    background-color: var(--card-bg);
    border-radius: 8px;
    justify-content: center;
    align-items: center;
    margin: 20px;
    padding: 20px;
    display: block;
    position: relative;
    bottom: 0;
    left: 0;
    right: 0;
    transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out, background-color 0.3s ease;
  }

  .Title {
    color: var(--text-primary);
    font-size: 24px;
    line-height: 1.8;
    margin: 0;
    transition: color 0.3s ease;
  }

  .Credits {
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 14px;
    line-height: 1.3;
    align-self: end;
    transition: color 0.3s ease;
  }

  @media (min-width: 768px) {
    .CardLink:hover .TitleGroup {
      opacity: 1;
    }
  }
</style>